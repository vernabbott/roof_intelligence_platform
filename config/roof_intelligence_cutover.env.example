# All centralized-reporting flags remain disabled until the final cutover.
ROOF_INTELLIGENCE_SUPABASE_ENABLED=0
ROOF_INTELLIGENCE_SUPABASE_READS_ENABLED=0
ROOF_INTELLIGENCE_SUPABASE_WRITES_ENABLED=0
ROOF_INTELLIGENCE_SUPABASE_WORKER_ENABLED=0
ROOF_INTELLIGENCE_SUPABASE_SHADOW_WRITES_ENABLED=0

# PCS will eventually receive only its public project URL/key and authenticated
# user session. Never place the service-role key in PCS or browser settings.
SUPABASE_URL=https://replace-with-staging-project.supabase.co
SUPABASE_ANON_KEY=replace-with-staging-anon-key

# Worker-only secrets belong in its private runtime environment or GitHub
# Actions secrets during CI/deployment. Do not commit real values.
SUPABASE_SERVICE_ROLE_KEY=replace-in-worker-secret-store
DATABASE_URL=replace-in-worker-secret-store
