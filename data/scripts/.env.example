# Preferred when using the Supabase Session pooler:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:5432/postgres

# Or configure the direct database connection as separate values:
SUPABASE_DB_HOST=db.PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=replace_me
